            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/DepositReq"
            }
          }
        ],
        "tags": [
          "wallet-api"
        ]
      }
    },
    "/wallets/transfer": {
      "post": {
        "operationId": "TransferHandler",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
