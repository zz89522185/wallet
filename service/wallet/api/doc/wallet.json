      "title": "TransferResp",
      "required": [
        "transferId",
        "fromWalletId",
        "toWalletId",
        "amount",
        "remark",
        "fromWalletBalanceBefore",
        "fromWalletBalanceAfter",
        "toWalletBalanceBefore",
        "toWalletBalanceAfter"
